# Zuul gateway URL (backend API entry point)
# Leave empty for same-origin (when PWA is served through the gateway)
# Set to full URL only for cross-origin deployments (e.g. VITE_API_BASE_URL=https://api.example.com)
VITE_API_BASE_URL=
# Google OAuth2 client ID (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=<your-google-client-id>
# Apple Sign In service ID (from Apple Developer Console)
VITE_APPLE_CLIENT_ID=<your-apple-service-id>
