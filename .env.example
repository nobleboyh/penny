# PiggyMetrics Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Config Service
CONFIG_SERVICE_PASSWORD=<your-config-service-password>

# Service-to-service OAuth2 client secrets (must match auth-service registration)
ACCOUNT_SERVICE_PASSWORD=<your-account-service-password>
STATISTICS_SERVICE_PASSWORD=<your-statistics-service-password>
NOTIFICATION_SERVICE_PASSWORD=<your-notification-service-password>

# MongoDB password (shared across all service MongoDB instances)
MONGODB_PASSWORD=<your-mongodb-password>

# Notification Service — SMTP credentials for sending emails
NOTIFICATION_EMAIL_USER=<your-smtp-email@example.com>
NOTIFICATION_EMAIL_PASSWORD=<your-smtp-password>
